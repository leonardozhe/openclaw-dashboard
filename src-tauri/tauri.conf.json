{
  "productName": "MeetClaw",
  "version": "1.0.0",
  "identifier": "com.openclaw.meetclaw",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "MeetClaw - OpenClaw Desktop Manager",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}